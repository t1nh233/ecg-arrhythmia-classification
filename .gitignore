# ==========================================
# 1. MÔI TRƯỜNG PYTHON & IDE
# ==========================================
.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class
.vscode/
.idea/
.ipynb_checkpoints/
.DS_Store
Thumbs.db

# ==========================================
# 2. DỮ LIỆU (RAW & PROCESSED DATA)
# Ngăn chặn đẩy dữ liệu y tế nặng lên GitHub
# ==========================================
dataraw/raw/*
data/processed/*
*.npy
*.dat
*.atr
*.hea

# Giữ lại cấu trúc thư mục rỗng cho người khác clone về
!data/raw/.gitkeep
!data/processed/.gitkeep

# ==========================================
# 3. TRỌNG SỐ MÔ HÌNH (MODEL CHECKPOINTS)
# Tuyệt đối không push file .pth vì nó rất nặng
# ==========================================
checkpoints/*
*.pth
*.pt

# Giữ lại thư mục rỗng
!checkpoints/.gitkeep

# ==========================================
# 4. KẾT QUẢ ĐẦU RA (FIGURES & REPORTS)
# Đã MỞ KHÓA thư mục chứa ảnh (outputs/figure) để Git lưu lại
# ==========================================
outputs/report/*

# Giữ lại cấu trúc thư mục report
!outputs/report/.gitkeep

# Mở khóa cho 2 file báo cáo tổng quan (để show kết quả)
!outputs/report/quantitative_report.txt
!outputs/report/quantitative_report.csv

# Chặn các báo cáo riêng lẻ của bệnh nhân khi chạy predict
patient_*_report.csv

# ==========================================
# 5. LOGS & TRACKING (WANDB)
# ==========================================
wandb/
logs/