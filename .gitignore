# ==========================================
# 1. MÔI TRƯỜNG PYTHON (VIRTUAL ENV)
# ==========================================
.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class

# ==========================================
# 2. DỮ LIỆU (DATASETS)
# Rất quan trọng: Không push dữ liệu MIT-BIH lên Git
# ==========================================
data/raw/*
data/processed/*
*.csv
*.json

# (Tùy chọn) Giữ lại cấu trúc thư mục data nhưng bỏ qua file bên trong
!data/raw/.gitkeep
!data/processed/.gitkeep

# ==========================================
# 3. TRỌNG SỐ MÔ HÌNH (MODEL WEIGHTS)
# Các file .pth thường rất nặng (vài chục đến vài trăm MB)
# ==========================================
*.pth
*.pt

# ==========================================
# 4. LOGS & KẾT QUẢ ĐẦU RA (OUTPUTS)
# Bỏ qua các biểu đồ, báo cáo và logs của WandB sinh ra khi chạy
# ==========================================
wandb/
learning_curves.png
confusion_matrix.png
patient_diagnosis_report.csv
patient_*_report.csv
logs/

# # ==========================================
# # 5. JUPYTER NOTEBOOK
